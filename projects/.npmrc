loglevel=error
registry=https://registry.npmjs.org

strictStorePkgContentCheck=false
verifyStoreIntegrity=false

# зҪ‘з»ңдјҳеҢ–
network-concurrency=16
fetch-retries=3
fetch-timeout=60000

# дёҘж јдҪҝз”Ё peer dependencies
strict-peer-dependencies=false

# иҮӘеҠЁз”ҹжҲҗ lockfile
auto-install-peers=true

# lockfile й…ҚзҪ®
lockfile=true
prefer-frozen-lockfile=true

# еҰӮжһң lockfile еӯҳеңЁдҪҶиҝҮжңҹпјҢжӣҙж–°иҖҢдёҚжҳҜеӨұиҙ?resolution-mode=highest

# дёҚжҸҗзӨ?npm жӣҙж–°
update-notifier=false
